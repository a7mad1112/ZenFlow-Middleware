// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActionType {
  CONVERTER
  EMAIL
  DISCORD
  PDF
  AI_SUMMARIZER
}

model Pipeline {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  actionType  ActionType  @default(CONVERTER)
  enabledActions String[] @default(["DISCORD", "EMAIL"])
  discordEnabled Boolean   @default(true)
  emailEnabled   Boolean   @default(true)
  config      Json?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscribers Subscriber[]
  webhooks    Webhook[]
  tasks       Task[]

  @@map("pipelines")
}

model Subscriber {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  targetUrl  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pipelineId])
  @@map("subscribers")
}

model Webhook {
  id        String   @id @default(cuid())
  pipelineId String
  pipeline  Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  eventType String
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([pipelineId])
  @@map("webhooks")
}

model Task {
  id          String   @id @default(cuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  webhookId   String?
  webhook     Webhook? @relation(fields: [webhookId], references: [id], onDelete: SetNull)
  status      String   @default("pending") // pending, processing, completed, failed
  payload     Json
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  error       String?
  result      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  @@index([pipelineId])
  @@index([webhookId])
  @@index([status])
  @@map("tasks")
}
